{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "build": {
    "env": {
      "PYTHON_VERSION": "3.9",
      "PIP_NO_CACHE_DIR": "1",
      "TRANSFORMERS_CACHE": "/tmp/.cache"
    }
  }
}